{
  "name": "openclaw-hermes-bridge",
  "version": "0.1.0",
  "license": "MIT",
  "description": "OpenClaw-to-Hermes ACP bridge for Node.js with workflow-scoped session reuse, per-attempt timeouts, and schema-validated delegation.",
  "keywords": [
    "openclaw",
    "hermes",
    "acp",
    "agent-client-protocol",
    "bridge"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openclaw-hermes-bridge": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "OPENCLAW_HERMES_BRIDGE_E2E=1 vitest run test/e2e",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
